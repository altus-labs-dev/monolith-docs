# Monolith Docs — Dev Environment (GCE VM)
# Copy to .env on the VM at /opt/monolith-docs/.env

NODE_ENV=development
ONLYOFFICE_JWT_SECRET=<generate: openssl rand -base64 32>

PORT=3020
HOST=0.0.0.0
LOG_LEVEL=info
ONLYOFFICE_URL=http://onlyoffice:80
ONLYOFFICE_PUBLIC_URL=https://app.monolithdocs.com
API_PUBLIC_URL=https://app.monolithdocs.com
API_INTERNAL_URL=http://api:3020

CORS_ORIGINS=https://app.monolithdocs.com

# Consumer auth — configure for dev testing
# CONSUMER_API_KEY=<dev-test-key>
# CONSUMERS='[...]'

# Rate limiting
RATE_LIMIT_MAX=200

# Session TTL (24 hours)
SESSION_TTL_MS=86400000

# GCS (optional)
# GCS_PROJECT_ID=monolith-docs
# GCS_BUCKET=monolith-docs-files-dev
# SIGNED_URL_TTL_MS=14400000
