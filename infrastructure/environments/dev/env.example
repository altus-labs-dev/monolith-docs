# Monolith Docs — Dev Environment
# Copy to .env on the VM at /opt/monolith-docs/.env

# OnlyOffice JWT — change this
ONLYOFFICE_JWT_SECRET=change-me-dev

# API config
PORT=3020
HOST=0.0.0.0
LOG_LEVEL=info
ONLYOFFICE_URL=http://onlyoffice:80
ONLYOFFICE_PUBLIC_URL=https://docs-dev.monolithcrm.com
API_PUBLIC_URL=https://docs-dev.monolithcrm.com

# GCS — optional, only if Docs generates its own signed URLs
# GCS_PROJECT_ID=monolith-docs
# GCS_BUCKET=monolith-docs-files-dev
# SIGNED_URL_TTL_MS=14400000
