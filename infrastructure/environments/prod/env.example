# Monolith Docs — Prod Environment
# Copy to .env on the VM at /opt/monolith-docs/.env

# OnlyOffice JWT — use a strong random secret
ONLYOFFICE_JWT_SECRET=change-me-prod

# API config
PORT=3020
HOST=0.0.0.0
LOG_LEVEL=warn
ONLYOFFICE_URL=http://onlyoffice:80
ONLYOFFICE_PUBLIC_URL=https://docs.monolithcrm.com
API_PUBLIC_URL=https://docs.monolithcrm.com

# GCS
# GCS_PROJECT_ID=monolith-docs
# GCS_BUCKET=monolith-docs-files
# SIGNED_URL_TTL_MS=14400000
