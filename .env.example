# Monolith Docs — Local Development Environment
# Copy to .env and customize as needed

# OnlyOffice JWT secret — this default is for local dev only
ONLYOFFICE_JWT_SECRET=dev-only-secret-do-not-use-in-prod

# Environment mode — leave as development for local dev
# NODE_ENV=development

# Consumer auth — leave empty for local dev (auth disabled)
# To test with auth locally, uncomment and configure:
# CONSUMER_API_KEY=dev-test-key
# CONSUMERS='[{"id":"dev","name":"Dev Consumer","auth":{"mode":"api-key","key":"dev-test-key"}}]'

# CORS — leave empty for local dev (allows all origins)
# CORS_ORIGINS=http://localhost:3020

# Rate limiting (requests per minute)
# RATE_LIMIT_MAX=100

# Session TTL (milliseconds, default 24 hours)
# SESSION_TTL_MS=86400000

# OnlyOffice URLs (defaults work with docker-compose)
# ONLYOFFICE_PUBLIC_URL=http://localhost:8080
# API_PUBLIC_URL=http://localhost:3020
